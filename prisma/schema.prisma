generator client {
  provider = "prisma-client-js"
}

datasource db {
  // For local development with SQLite (default)
  provider = "sqlite"
  // For Vercel/Supabase deployment, change to:
  // provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  password     String
  avatar       String?
  bio          String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  pins         Pin[]
  likes        Like[]
  saves        Save[]
  comments     Comment[]
  followers    Follow[]  @relation("UserFollowers")
  following    Follow[]  @relation("UserFollowing")
  boards       Board[]
  notifications Notification[]
}

model Pin {
  id          String    @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String?
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes       Like[]
  saves       Save[]
  comments    Comment[]
  boardPins   BoardPin[]
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  pinId     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pin       Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)

  @@unique([userId, pinId])
}

model Save {
  id        String   @id @default(cuid())
  userId    String
  pinId     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pin       Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)

  @@unique([userId, pinId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  pinId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pin       Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Board {
  id          String     @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  userId      String
  isPrivate   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pins        BoardPin[]

  @@unique([userId, name])
}

model BoardPin {
  id        String   @id @default(cuid())
  boardId   String
  pinId     String
  createdAt DateTime @default(now())

  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  pin       Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)

  @@unique([boardId, pinId])
}

model Notification {
  id         String   @id @default(cuid())
  type       String
  message    String
  fromUserId String
  toUserId   String
  pinId      String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  toUser     User     @relation(fields: [toUserId], references: [id], onDelete: Cascade)
}
